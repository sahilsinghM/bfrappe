# Copy this file to .env and fill in values before deploying.
# .env is gitignored — never commit it.

# Docker image name (used by docker-compose.yml)
IMAGE=basic-spine:latest

# Site name — use the domain you'll point at this VPS, or a plain hostname.
# Must match FRAPPE_SITE_NAME_HEADER served by nginx.
SITE_NAME=spine.example.com

# MariaDB root password — pick something strong
DB_ROOT_PASSWORD=changeme_db

# Frappe Administrator password for the site
ADMIN_PASSWORD=changeme_admin

# Port the nginx frontend listens on (host-side)
HTTP_PORT=8080
